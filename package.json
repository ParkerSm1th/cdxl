{
  "name": "codexlink",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "build": "pnpm -r build",
    "build:api": "pnpm --filter @codexlink/db build && pnpm --filter @codexlink/api build",
    "build:web": "pnpm --filter @codexlink/web build",
    "check": "pnpm -r typecheck && pnpm test",
    "dev": "pnpm -r --parallel --stream dev",
    "migrate:deploy": "node packages/db/dist/migrate.js",
    "publish:cli": "pnpm --filter codex-link publish:npm",
    "start:api": "pnpm --filter @codexlink/api start",
    "start:web": "pnpm --filter @codexlink/web start",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.5.2",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "dotenv": "^16.6.1",
    "drizzle-kit": "^0.31.4",
    "jsdom": "^26.1.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
