{
  "name": "codex-link",
  "version": "0.1.2",
  "type": "module",
  "bin": {
    "cdxl": "dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
